# =============================================================
# Asistente IA de Agenda Ejecutiva — Variables de Entorno
# =============================================================
# Copia este archivo como .env.local para desarrollo local.
# En Railway: configura cada variable en el panel Variables.
# NUNCA subas .env.local ni .env al repositorio.
#
# Para generar JWT_SECRET:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Para generar EXECUTIVE_PASSWORD_HASH:
#   npm run gen:hash -- "TuContraseña"  →  copia el valor "Base64 para .env"
# =============================================================


# ─── Base de datos (Supabase) ─────────────────────────────────
# URL con PgBouncer modo transacción — servidor de aplicación (puerto 6543)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# URL directa sin pooler — solo para migraciones Prisma (puerto 5432)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"


# ─── Autenticación JWT ────────────────────────────────────────
# Clave secreta para firmar tokens. Mínimo 32 bytes, formato base64.
JWT_SECRET="<base64-random-32-bytes>"


# ─── Ejecutivo (credenciales de acceso) ───────────────────────
EXECUTIVE_EMAIL="ejecutivo@agenda.local"

# Hash bcrypt en base64 (evita que dotenv expanda el prefijo $2b$).
# Genera con: npm run gen:hash -- "TuContraseña"  → usa el valor "Base64 para .env"
EXECUTIVE_PASSWORD_HASH="<bcrypt-hash-en-base64>"


# ─── OpenAI (opcional) ────────────────────────────────────────
# Sin esta variable el sistema usa NullLLMAdapter (respuestas locales deterministas).
# OPENAI_API_KEY="sk-..."
# LLM_MODEL="gpt-4o-mini"


# ─── Google Calendar (opcional) ───────────────────────────────
# Sin estas variables el sistema usa NullCalendarAdapter (sin sincronización).
# Instrucciones de configuración: ver agent/directives/f3-google-cloud-setup.md
#
# Client ID y Secret: Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
#
# URI de callback — debe coincidir exactamente con la registrada en Google Cloud Console
# Desarrollo:  http://localhost:3000/api/auth/google/callback
# Producción:  https://tu-dominio.railway.app/api/auth/google/callback
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"
#
# Clave de encriptación AES-256-GCM para los tokens OAuth (recomendado en producción)
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
GOOGLE_TOKEN_ENCRYPTION_KEY=""


# ─── Pesos de priorización (opcional) ────────────────────────
# Suma debe ser 1.0. Valores por defecto: 0.5 / 0.3 / 0.2
# PRIORITY_WEIGHT_URGENCY="0.5"
# PRIORITY_WEIGHT_IMPACT="0.3"
# PRIORITY_WEIGHT_LOAD="0.2"


# ─── Servidor (Railway lo inyecta automáticamente) ────────────
# PORT=3000
# NODE_ENV=production

# Google Calendar (opcional — dejar en blanco si no se usa)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Genera con: openssl rand -base64 32
CALENDAR_ENCRYPTION_KEY=""

# Servidor
# En Railway se configura automáticamente
PORT="3000"
NODE_ENV="development"
